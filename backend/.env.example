###############################################
# APLICACION
###############################################

# Nombre de la aplicacion
APP_NAME=SistemaFotocheck

# Entorno: local, testing, production
APP_ENV=local

# Clave de encriptacion (generar con: php artisan key:generate)
# NUNCA subir la clave real al repositorio
APP_KEY=

# Modo debug: true en desarrollo, false en produccion
APP_DEBUG=true

# URL base del backend (sin slash al final)
APP_URL=http://localhost

# URL del frontend para CORS y redireccionamiento
# En produccion: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173

###############################################
# LOCALIZACION
###############################################

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

###############################################
# MANTENIMIENTO
###############################################

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

###############################################
# SERVIDOR
###############################################

# Rondas de hash bcrypt (mas alto = mas seguro pero mas lento)
BCRYPT_ROUNDS=12

# Numero de workers para el servidor PHP (produccion)
# PHP_CLI_SERVER_WORKERS=4

###############################################
# LOGS
###############################################

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

###############################################
# BASE DE DATOS (MySQL)
###############################################

DB_CONNECTION=mysql

# Host de la base de datos
DB_HOST=127.0.0.1

# Puerto de MySQL
DB_PORT=3306

# Nombre de la base de datos
DB_DATABASE=sistema_fotocheck

# Usuario de MySQL
DB_USERNAME=root

# Contrasena de MySQL (vacio si no tiene)
DB_PASSWORD=

###############################################
# SESIONES
###############################################

# Driver: database, file, cookie, redis, memcached, array
SESSION_DRIVER=database

# Tiempo de vida de la sesion en minutos
# El frontend tambien usa este valor para expirar sesiones
SESSION_LIFETIME=120

# Cifrar cookies de sesion (true/false)
SESSION_ENCRYPT=false

SESSION_PATH=/

# Dominio de las cookies (null = dominio actual)
SESSION_DOMAIN=null

###############################################
# COLA Y CACHE
###############################################

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Driver de colas: database, redis, sqs, sync
QUEUE_CONNECTION=database

# Driver de cache: database, file, redis, memcached, array
CACHE_STORE=database
# CACHE_PREFIX=

###############################################
# MEMCACHED (opcional)
###############################################

MEMCACHED_HOST=127.0.0.1

###############################################
# REDIS (opcional, para cache/sesiones en produccion)
###############################################

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

###############################################
# CORREO ELECTRONICO
###############################################

# Mailer: smtp, mailgun, postmark, resonances, ses, log, array, failover
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="rrhh@unap.edu.pe"
MAIL_FROM_NAME="${APP_NAME}"

###############################################
# SERVICIOS EN LA NUBE (opcional)
###############################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

###############################################
# FRONTEND (Vite lee estas variables)
###############################################

VITE_APP_NAME="${APP_NAME}"

###############################################
# FOTOCHECK - QR y encriptacion
###############################################

# Clave secreta para encriptar datos del fotocheck
# Generar con: openssl rand -hex 32
FOTOCHECK_KEY=

# Vector de inicializacion para encriptacion (16 caracteres)
# Generar con: openssl rand -hex 8
FOTOCHECK_IV=
