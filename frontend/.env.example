###############################################
# FRONTEND - VARIABLES DE ENTORNO
###############################################

# Prefijo de rutas API (se usa en todas las peticiones fetch)
# En produccion: /api
# En desarrollo: /api
VITE_API_URL=/api

# URL del backend para el proxy de Vite (solo desarrollo)
# En produccion NO se usa, Apache/Nginx maneja el proxy
# Ejemplo: http://localhost/fotocheck-project/backend/public
VITE_BACKEND_URL=http://localhost/fotocheck-project/backend/public
